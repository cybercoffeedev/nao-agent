{
    "name": "nao-devcontainer",
    "dockerComposeFile": [
        "../docker-compose.yml"
    ],
    "service": "dev",
    "workspaceFolder": "/home/nao-agent",
    "forwardPorts": [4096],
    "portsAttributes": {
        "4096": {
            "label": "OpenCode Web",
            "onAutoForward": "openBrowser"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python"
            ]
        }
    }
}
